---
title: People
permalink: /people/
layout: base.njk
---

<h1>{{ title }}</h1>

<div class="grid grid-cols-3 mb-4">
  {% for member in members | sortByLastName %}
  <div class="card member-card">
    {% if member.image %}
    <img src="{{ member.image }}" alt="{{ member.name }}" class="member-image">
    {% else %}
    <div class="member-image" style="background-color: var(--color-border);"></div>
    {% endif %}
    <h3>{{ member.name }}</h3>
    <p>{{ member.position }}</p>
    {% if member.email %}
      <p>
        <script type="text/javascript">
          var user = "{{ member.name }}".split(" ")[1];
          var domain = "umassmed.edu";
          document.write('<a href="mailto:' + user + '@' + domain + '">Email</a>');
        </script>
        <noscript>Email hidden</noscript>
      </p>
    {% endif %}
    {% if member.interests %}
    <p><strong>Interests:</strong><br>
      {% for interest in member.interests %}
      {{ interest }}{% if not loop.last %}, {% endif %}
      {% endfor %}
    </p>
    {% endif %}
  </div>
  {% endfor %}
</div>

<h2>Alumni</h2>

<div class="grid grid-cols-4">
  {% for alum in alumni %}
  <div class="card member-card">
    {% if alum.image %}
    <img src="{{ alum.image }}" alt="{{ alum.name }}" class="member-image">
    {% else %}
    <div class="member-image" style="background-color: var(--color-border);"></div>
    {% endif %}
    <h3>{{ alum.name }}</h3>
    <p>Former {{ alum.position }}</p>
  </div>
  {% endfor %}
</div>
